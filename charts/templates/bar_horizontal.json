{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Horizontal bar chart — rounded right corners, no axis lines",
  "width": 600,
  "height": "__DYNAMIC_HEIGHT__",
  "padding": {"left": 16, "right": 24, "top": 20, "bottom": 12},
  "data": {"values": "__DATA__"},
  "mark": {
    "type": "bar",
    "cornerRadiusTopRight": 6,
    "cornerRadiusBottomRight": 6,
    "opacity": 0.92,
    "cursor": "pointer",
    "height": {"band": 0.72}
  },
  "encoding": {
    "y": {
      "field": "__CATEGORICAL__",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "labelFontSize": 11,
        "labelColor": "#374151",
        "labelLimit": 200,
        "titleFontSize": 12,
        "titleColor": "#374151",
        "titleFontWeight": 500,
        "titlePadding": 12,
        "domain": false,
        "ticks": false,
        "grid": false
      }
    },
    "x": {
      "field": "__NUMERIC__",
      "type": "quantitative",
      "title": "__NUMERIC_TITLE__",
      "axis": {
        "labelFontSize": 11,
        "labelColor": "#9ca3af",
        "titleFontSize": 12,
        "titleColor": "#374151",
        "titleFontWeight": 500,
        "titlePadding": 12,
        "domain": false,
        "ticks": false,
        "gridColor": "#f3f4f6",
        "gridOpacity": 0.8,
        "gridDash": [3, 3],
        "format": ",.0f"
      }
    },
    "color": {
      "field": "__CATEGORICAL__",
      "type": "nominal",
      "scale": {
        "range": [
          "#6366f1", "#f59e0b", "#10b981", "#ef4444",
          "#8b5cf6", "#ec4899", "#06b6d4", "#f97316",
          "#14b8a6", "#a855f7", "#eab308", "#64748b"
        ]
      },
      "legend": null
    },
    "tooltip": [
      {"field": "__CATEGORICAL__", "type": "nominal", "title": "__CATEGORICAL_TITLE__"},
      {"field": "__NUMERIC__", "type": "quantitative", "format": ",.2f", "title": "__NUMERIC_TITLE__"}
    ]
  },
  "config": {
    "background": "#ffffff",
    "font": "Inter, Segoe UI, Roboto, sans-serif",
    "view": {"stroke": "transparent"},
    "title": {
      "fontSize": 16,
      "fontWeight": 600,
      "color": "#1a1a2e",
      "anchor": "start",
      "offset": 14
    }
  }
}